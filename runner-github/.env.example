# === REQUIRED ===

# GitHub PAT with repo access for PR/commit comments AND runner registration.
# Must have scopes:
#   - Administration: Write  (to generate runner registration tokens)
#   - Issues: Write          (to post PR comments)
#   - Pull requests: Write   (to post PR comments)
#   - Contents: Write        (to post commit comments)
GH_TOKEN=

# Gemini API key for AI diagnosis
# Get one at https://aistudio.google.com/apikey
LLM_API_KEY=

# GitHub owner and repo (e.g., "my-org" and "my-repo")
# Used to auto-generate runner registration tokens on every container start.
GITHUB_OWNER=
GITHUB_REPO=

# === OPTIONAL ===

# Runner name (default: ci-triage-runner-<hostname>)
RUNNER_NAME=

# Runner labels (default: self-hosted,ci-triage)
RUNNER_LABELS=self-hosted,ci-triage

# Runner group (default: default)
RUNNER_GROUP=default

# LLM provider (gemini, openai, anthropic) default: gemini
LLM_PROVIDER=gemini

# Number of log lines to analyze (default: 200)
LOG_LINES=200

# LLM API timeout in seconds (default: 60)
LLM_TIMEOUT=60

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
