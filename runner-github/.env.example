# Required — GitHub URL (org or repo level)
# Example: https://github.com/my-org
GITHUB_URL=

# Required — Runner registration token (from Settings → Actions → Runners)
RUNNER_TOKEN=

# Required — Gemini API key for AI diagnosis
# Get one at https://aistudio.google.com/apikey
LLM_API_KEY=

# Required — GitHub PAT with repo scope for posting PR/commit comments
# Must have: contents:write and pull-requests:write
GITHUB_TOKEN=

# Optional — Runner name (default: ci-triage-runner-<hostname>)
RUNNER_NAME=

# Optional — Runner labels (default: self-hosted,ci-triage)
RUNNER_LABELS=self-hosted,ci-triage

# Optional — Runner group (default: default)
RUNNER_GROUP=default

# Optional — Replace existing runner with same name (default: true)
REPLACE_RUNNER=true

# Optional — LLM provider (gemini, openai, anthropic) default: gemini
LLM_PROVIDER=gemini

# Optional — number of log lines to analyze (default: 200)
LOG_LINES=200

# Optional — LLM API timeout in seconds (default: 60)
LLM_TIMEOUT=60

# Optional — Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
