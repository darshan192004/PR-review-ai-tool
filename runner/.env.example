# Required — Gemini API key for AI diagnosis
# Get one at https://aistudio.google.com/apikey
LLM_API_KEY=AIzaSy...

# Required — Forgejo access token for posting PR comments
# Create a bot user on your Forgejo server, then generate a token at:
# Settings → Applications → Generate Token (scope: write:repository)
GITEA_TOKEN=your-forgejo-bot-token-here

# Required — Your Forgejo server URL
FORGEJO_URL=https://forgejo.yourcompany.com

# Optional — number of log lines to analyze (default: 200)
LOG_LINES=200

# Optional — LLM API timeout in seconds (default: 60)
LLM_TIMEOUT=60

# Optional — LLM provider (gemini, openai, anthropic) default: gemini
LLM_PROVIDER=gemini
